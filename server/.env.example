# Database Configuration
MONGO_URI=mongodb://localhost:27017/dais
NODE_ENV=development

# Server Configuration
PORT=5000
BASE_URL=http://localhost:5000
API_URL=http://localhost:5000/api/v1
FRONTEND_URL=http://localhost:3000

# JWT Configuration
JWT_SECRET_KEY=your-super-secret-jwt-key-change-this-in-production
JWT_EXPIRES_IN=7d
ACCESS_TOKEN_SECRET=your-access-token-secret
ACCESS_TOKEN_EXPIRES=1h
REFRESH_TOKEN_SECRET=your-refresh-token-secret
REFRESH_TOKEN_EXPIRES=7d

# Email Configuration (Gmail example)
EMAIL_USER=your-email@gmail.com
EMAIL_PASSWORD=your-app-password
EMAIL_FROM=noreply@dais.com
EMAIL=your-email@gmail.com
EMAIL_SERVICE=gmail

# Inactivity Configuration (in days)
INACTIVITY_WARNING_DAYS=60
INACTIVITY_THRESHOLD_DAYS=90
INACTIVITY_REMINDER_INTERVAL_DAYS=7

# Encryption Configuration
ENCRYPTION_ALGORITHM=AES-256-GCM

# Redis Configuration (optional)
REDIS_HOST=localhost
REDIS_PORT=6379

# AWS Configuration (optional - if needed for future file storage)
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=us-east-1
AWS_BUCKET_NAME=
